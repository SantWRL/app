<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Quando o botão é pressionado, ele "desce" -->
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="4dp">
                <shape>
                    <solid android:color="@color/duo_green" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Estado normal com a sombra de 4dp no fundo -->
    <item>
        <layer-list>
            <!-- Camada da Sombra (Fundo) -->
            <item>
                <shape>
                    <solid android:color="@color/duo_green_dark" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
            <!-- Camada do Topo (Cor Principal) deslocada para cima -->
            <item android:bottom="4dp">
                <shape>
                    <solid android:color="@color/duo_green" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
