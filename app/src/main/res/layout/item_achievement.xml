<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="184dp"
    android:layout_height="156dp"
    android:layout_marginHorizontal="6dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="@dimen/card_corner_radius_small"
    app:cardElevation="@dimen/card_elevation"
    app:strokeColor="@color/border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="14dp">

        <FrameLayout
            android:id="@+id/achievementIconContainer"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_achievement_icon">

            <ImageView
                android:id="@+id/achievementIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="@string/profile_achievements"
                android:src="@drawable/ic_star"
                app:tint="@color/accent" />

        </FrameLayout>

        <TextView
            android:id="@+id/achievementName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Primeiro passo"
            android:textAppearance="@style/TextAppearance.LGPD.Body"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="Guardião dos dados" />

        <TextView
            android:id="@+id/achievementDescription"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="4dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Concluiu a introdução à LGPD."
            android:textAppearance="@style/TextAppearance.LGPD.BodySmall"
            android:textSize="12sp"
            tools:text="Aprendeu a identificar dados pessoais e sensíveis." />

        <TextView
            android:id="@+id/achievementStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Desbloqueada"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            tools:text="Em progresso" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
